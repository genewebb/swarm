{"$schema":"http://json-schema.org/draft-07/schema#","$id":"verifier.schema.json","title":"Verifier Result","description":"Schema for verifier.result.json produced by the verifier subagent","type":"object","required":["schemaVersion","subagent","runId","handoffId","verdict","summary","verifiedItems","issues","createdAt"],"additionalProperties":false,"properties":{"schemaVersion":{"type":"string","const":"1.0","description":"Schema version"},"subagent":{"type":"string","const":"verifier","description":"Identifies the producing agent"},"runId":{"type":"string","description":"The run id from the handoff"},"handoffId":{"type":"string","description":"The handoff this result responds to"},"verdict":{"type":"string","enum":["passed","failed"],"description":"passed if implementation verified functional; failed if issues found"},"summary":{"type":"string","description":"Brief summary of the verification"},"verifiedItems":{"type":"array","description":"What was verified and passed","items":{"type":"string"}},"issues":{"type":"array","description":"Issues found: incomplete, broken, or edge cases missed","items":{"type":"object","required":["description"],"properties":{"description":{"type":"string"},"file":{"type":"string"},"line":{"type":"integer"},"category":{"type":"string","enum":["incomplete","broken","edge-case","other"]}}}},"notes":{"type":"string","description":"Optional notes"},"createdAt":{"type":"string","format":"date-time","description":"ISO 8601 timestamp when verification was completed"}}}
